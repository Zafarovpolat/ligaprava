{
  "name": "altagrad-lawyers",
  "version": "1.0.0",
  "description": "Лендинг для юридической компании АЛЬТАГРАД LAWYERS",
  "main": "index.html",
  "scripts": {
    "build": "sass scss/style.scss css/style.css --style=expanded --source-map",
    "watch": "sass scss/style.scss css/style.css --style=expanded --source-map --watch",
    "dev": "concurrently \"npm run watch\" \"live-server --port=3000\"",
    "build-prod": "sass scss/style.scss css/style.css --style=compressed --no-source-map && postcss css/style.css --use autoprefixer --replace",
    "build:dist": "node scripts/build.js",
    "predeploy": "npm run build:dist"
  },
  "keywords": [
    "lawyers",
    "legal",
    "landing",
    "bitrix",
    "sass",
    "responsive"
  ],
  "author": "Developer",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "sass": "^1.69.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
